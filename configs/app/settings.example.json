{
  "camera": {
    "name": "front-door-camera",
    "source_type": "network",
    "stream_url": "http://YOUR_CAMERA_URL_HERE/stream",
    "rtsp_url": "",
    "usb_index": 0,
    "live_frame_width": 1280,
    "live_frame_height": 720
  },
  "recording": {
    "ffmpeg_path": "ffmpeg",
    "segment_seconds": 60,
    "output_pattern": "data/recordings/frontdoor_%Y%m%d_%H%M%S.mp4",
    "log_file": "data/logs/ingest.log"
  },
  "ingest": {
    "capture_fps": 12,
    "output_fps": 10,
    "reconnect_delay_seconds": 2,
    "stale_frame_seconds": 5
  },
  "storage": {
    "sqlite_path": "data/events/events.db"
  },
  "jobs": {
    "enabled": true,
    "poll_interval_seconds": 2,
    "retry_delay_seconds": 10,
    "stale_running_seconds": 300,
    "sample_limit": 100
  },
  "detection": {
    "model_path": "yolov8n.pt",
    "confidence_threshold": 0.45,
    "frame_skip": 1,
    "target_classes": [
      "person"
    ],
    "cooldown_seconds": 8,
    "frame_source": "backend_live_frame",
    "backend_live_frame_url": "",
    "frame_fetch_timeout_seconds": 3,
    "source_retry_delay_seconds": 1,
    "source_poll_fps": 3,
    "inference_max_fps": 2,
    "motion_gate_enabled": true,
    "motion_min_changed_ratio": 0.003,
    "motion_pixel_threshold": 22,
    "motion_resize_width": 320,
    "motion_blur_kernel": 5,
    "motion_force_inference_interval_seconds": 12,
    "status_log_interval_seconds": 60,
    "log_file": "data/logs/detector.log",
    "log_level": "INFO",
    "write_legacy_ndjson": false,
    "events_file": "data/events/events.ndjson",
    "snapshot_dir": "data/snapshots"
  },
  "alerts": {
    "enabled": false,
    "webhook_enabled": true,
    "webhook_url": "",
    "timeout_seconds": 6,
    "enqueue_background": true,
    "job_max_attempts": 3,
    "access_links": {
      "local_url": "",
      "tailscale_url": "",
      "auto_detect_local": true,
      "auto_detect_tailscale": true,
      "dashboard_port": 8080
    },
    "smtp": {
      "enabled": false,
      "host": "YOUR_SMTP_HOST_HERE",
      "port": 587,
      "use_starttls": true,
      "timeout_seconds": 10,
      "username": "YOUR_SMTP_USERNAME_HERE",
      "password": "YOUR_SMTP_PASSWORD_HERE",
      "from_email": "YOUR_FROM_EMAIL_HERE",
      "to_emails": [
        "YOUR_ALERT_EMAIL_HERE"
      ],
      "subject_prefix": "Doorbell Alert",
      "max_attachment_mb": 8,
      "include_snapshot": true,
      "include_clip_default": false
    }
  },
  "auth": {
    "enabled": false,
    "session_secret": "PUT_LONG_RANDOM_SESSION_SECRET_HERE",
    "session_hours": 24
  },
  "api": {
    "host": "0.0.0.0",
    "port": 8080
  }
}
